generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================================================
// AUTO-GENERATED — do not edit this file directly.
// Source of truth : prisma/schema.prisma  (root master schema)
// Regenerate      : node scripts/generate-schemas.js
// Migrations      : run ONLY from root — npx prisma migrate dev --schema prisma/schema.prisma
// =====================================================================================

// ─── Enums ───────────────────────────────────────────────────────────────────────

enum Language {
  ES
  EN
  FR
  PT
  DE
}

enum ServicePricing {
  FIXED
  QUOTATION
  HOURLY
  PACKAGE
}

enum QuotationStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  EXPIRED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── Models ──────────────────────────────────────────────────────────────────────

model ServiceCategory {
  id            Int                          @id @default(autoincrement())
  isActive      Boolean                      @default(true)
  sortOrder     Int                          @default(0)
  featuredFrom  DateTime?
  featuredUntil DateTime?
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  subcategories ServiceSubCategory[]
  translations  ServiceCategoryTranslation[]

  @@index([isActive, sortOrder])
  @@index([featuredUntil])
}

model ServiceCategoryTranslation {
  id                Int             @id @default(autoincrement())
  serviceCategoryId Int
  language          Language
  category          String
  slug              String
  href              String?
  metaTitle         String?
  metaDescription   String?
  metaKeywords      String[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)

  @@unique([serviceCategoryId, language])
  @@unique([slug, language])
  @@index([slug, language])
  @@index([language, serviceCategoryId])
}

model ServiceSubCategory {
  id                Int                             @id @default(autoincrement())
  serviceCategoryId Int
  isActive          Boolean                         @default(true)
  sortOrder         Int                             @default(0)
  featuredFrom      DateTime?
  featuredUntil     DateTime?
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt
  services          Service[]
  serviceFAQ        ServiceFAQ[]
  serviceCategory   ServiceCategory                 @relation(fields: [serviceCategoryId], references: [id])
  translations      ServiceSubCategoryTranslation[]

  @@index([serviceCategoryId])
  @@index([isActive, sortOrder])
  @@index([featuredUntil])
}

model ServiceSubCategoryTranslation {
  id                   Int                @id @default(autoincrement())
  serviceSubCategoryId Int
  language             Language
  subCategory          String
  slug                 String
  href                 String?
  metaTitle            String?
  metaDescription      String?
  metaKeywords         String[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  serviceSubCategory   ServiceSubCategory @relation(fields: [serviceSubCategoryId], references: [id], onDelete: Cascade)

  @@unique([serviceSubCategoryId, language])
  @@unique([slug, language])
  @@index([slug, language])
  @@index([language, serviceSubCategoryId])
}

model Service {
  id                 Int                  @id @default(autoincrement())
  name               String
  description        String?
  sellerId           String
  pricingType        ServicePricing       @default(QUOTATION)
  basePrice          Float?
  priceRange         String?
  duration           Int?
  isActive           Boolean              @default(true)
  images             String[]
  tags               String[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  subcategoryId      Int
  averageRating      Float?               @default(0)
  viewCount          Int                  @default(0)
  quotation          Quotation[]
  likes              ServiceLike[]
  serviceCategory    ServiceSubCategory   @relation(fields: [subcategoryId], references: [id])
  serviceBooking     ServiceBooking[]
  serviceFAQ         ServiceFAQ[]
  serviceMedia       ServiceMedia[]
  servicePackageItem ServicePackageItem[]
  serviceReview      ServiceReview[]

  @@index([subcategoryId])
  @@index([isActive])
  @@index([pricingType])
  @@index([sellerId])
  @@index([sellerId, isActive])
  @@index([subcategoryId, isActive])
  @@index([sellerId, isActive, pricingType])
  @@index([createdAt(sort: Desc), isActive])
  @@index([averageRating])
  @@index([viewCount])
}

model ServiceReview {
  id                 Int             @id @default(autoincrement())
  serviceId          Int
  reviewerId         String
  rating             Int
  comment            String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  bookingId          Int?
  helpfulCount       Int             @default(0)
  isVerifiedPurchase Boolean         @default(false)
  providerResponse   String?
  providerResponseAt DateTime?
  quotationId        Int?
  reportCount        Int             @default(0)
  serviceBooking     ServiceBooking? @relation(fields: [bookingId], references: [id])
  quotation          Quotation?      @relation(fields: [quotationId], references: [id])
  service            Service         @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, reviewerId])
  @@index([bookingId])
  @@index([isVerifiedPurchase])
  @@index([quotationId])
  @@index([reviewerId, createdAt(sort: Desc)])
  @@index([reviewerId])
  @@index([serviceId, createdAt(sort: Desc)])
  @@index([serviceId])
  @@index([serviceId, rating(sort: Desc)])
}

model Quotation {
  id                                  Int             @id @default(autoincrement())
  serviceId                           Int
  clientId                            String
  providerId                          String
  title                               String
  description                         String
  estimatedPrice                      Float?
  finalPrice                          Float?
  estimatedDuration                   Int?
  status                              QuotationStatus @default(PENDING)
  clientNotes                         String?
  providerNotes                       String?
  attachments                         String[]
  createdAt                           DateTime        @default(now())
  updatedAt                           DateTime        @updatedAt
  expiresAt                           DateTime?
  acceptedAt                          DateTime?
  completedAt                         DateTime?
  actualCompletionDate                DateTime?
  actualStartDate                     DateTime?
  cancellationReason                  String?
  declineReason                       String?
  depositAmount                       Float?
  depositPaid                         Boolean         @default(false)
  estimatedCompletionDate             DateTime?
  estimatedStartDate                  DateTime?
  previousVersions                    Json?
  priceBreakdown                      Json?
  revisionCount                       Int             @default(0)
  service                             Service         @relation(fields: [serviceId], references: [id])
  serviceReview                       ServiceReview[]

  @@index([clientId])
  @@index([clientId, status])
  @@index([depositPaid])
  @@index([estimatedStartDate])
  @@index([expiresAt])
  @@index([providerId])
  @@index([providerId, status])
  @@index([serviceId])
  @@index([serviceId, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([status, estimatedStartDate])
  @@index([status, expiresAt])
  @@index([status])
}

model ServiceBooking {
  id                 Int             @id @default(autoincrement())
  serviceId          Int
  clientId           String
  providerId         String
  bookingDate        DateTime        @default(now())
  scheduledDate      DateTime
  scheduledTimeSlot  String?
  serviceLocation    Json?
  agreedPrice        Float
  paymentStatus      PaymentStatus   @default(PENDING)
  status             BookingStatus   @default(PENDING)
  clientNotes        String?
  providerNotes      String?
  completedAt        DateTime?
  cancellationReason String?
  cancelledBy        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  service            Service         @relation(fields: [serviceId], references: [id])
  serviceReview      ServiceReview[]

  @@index([clientId, status])
  @@index([paymentStatus])
  @@index([providerId, scheduledDate])
  @@index([providerId, status])
  @@index([scheduledDate])
  @@index([serviceId, status])
  @@index([status, scheduledDate])
}

model ServiceFAQ {
  id                 Int                 @id @default(autoincrement())
  serviceId          Int?
  subcategoryId      Int?
  question           String
  answer             String
  displayOrder       Int                 @default(0)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  service            Service?            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceSubCategory ServiceSubCategory? @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([serviceId, displayOrder])
  @@index([subcategoryId, displayOrder])
}

model ServiceMedia {
  id            Int      @id @default(autoincrement())
  serviceId     Int
  mediaType     String
  url           String
  title         String?
  description   String?
  displayOrder  Int      @default(0)
  isPortfolio   Boolean  @default(false)
  isCertificate Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([mediaType])
  @@index([serviceId, displayOrder])
  @@index([serviceId, isCertificate])
  @@index([serviceId, isPortfolio])
}

model ServicePackage {
  id                 Int                  @id @default(autoincrement())
  sellerId           String
  name               String
  description        String
  totalPrice         Float
  discountPercentage Float?               @default(0)
  validityDays       Int?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  servicePackageItem ServicePackageItem[]

  @@index([isActive])
  @@index([sellerId, isActive])
}

model ServicePackageItem {
  id             Int            @id @default(autoincrement())
  packageId      Int
  serviceId      Int
  quantity       Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  servicePackage ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service        Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([packageId, serviceId])
  @@index([packageId])
  @@index([serviceId])
}

model ServiceProviderCredentials {
  id                    Int       @id @default(autoincrement())
  sellerId              String    @unique
  licenseNumber         String?
  licenseType           String?
  licenseExpiryDate     DateTime?
  isLicenseVerified     Boolean   @default(false)
  insuranceProvider     String?
  insurancePolicyNumber String?
  insuranceExpiryDate   DateTime?
  insuranceCoverage     Float?
  certifications        Json?
  backgroundCheckDate   DateTime?
  backgroundCheckStatus String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([backgroundCheckStatus])
  @@index([insuranceExpiryDate])
  @@index([isLicenseVerified])
  @@index([licenseExpiryDate])
}

model ServiceLike {
  id        Int      @id @default(autoincrement())
  sellerId  String
  serviceId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, sellerId])
  @@index([serviceId])
  @@index([sellerId])
  @@index([createdAt(sort: Desc)])
}

